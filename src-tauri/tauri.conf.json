{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photo Unloader",
  "version": "0.1.0",
  "identifier": "com.photo.unloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Photo Unloader",
        "width": 980,
        "height": 720,
        "minWidth": 820,
        "minHeight": 580,
        "center": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"]
  }
}
